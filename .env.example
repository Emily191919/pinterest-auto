# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Pinterest ─────────────────────────────────────────────────────────────────
# Generate an access token via https://developers.pinterest.com/
# Required scopes: boards:read, boards:write, pins:read, pins:write, media:write
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
PINTEREST_APP_ID=your_app_id
PINTEREST_APP_SECRET=your_app_secret

# ── Etsy Shop ─────────────────────────────────────────────────────────────────
ETSY_SHOP_NAME=My Etsy Shop
ETSY_SHOP_URL=https://www.etsy.com/shop/YourShopName

# ── Runtime Settings ──────────────────────────────────────────────────────────
# Path to the folder containing your product images
IMAGE_FOLDER=./images

# Maximum number of pins to post per run (0 = no limit)
MAX_PINS_PER_RUN=0

# Seconds to pause between posting consecutive pins
DELAY_BETWEEN_PINS=3
